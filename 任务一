import numpy as np

# 1. 创建形状 (3,4) 的0~9随机整数数组
arr = np.random.randint(0, 10, size=(3, 4))
print("原数组 (3×4):")
print(arr)

# 2. 重塑为 (4,3) 后转置
reshaped_arr = arr.reshape(4, 3).T
print("\n重塑+转置后 (3×4):")
print(reshaped_arr)

# 3. 布尔索引提取所有大于5的元素
filtered_arr = arr[arr > 5]
print("\n大于5的元素:")
print(filtered_arr)
